{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "LQNN Quantum Brain",
  "version": "3.0.0",
  "identifier": "com.lqnn.quantum-brain",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:8000/terminal"
  },
  "app": {
    "title": "LQNN v3 -- Quantum Brain",
    "windows": [
      {
        "title": "LQNN v3 -- Quantum Brain",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
